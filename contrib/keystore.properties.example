# Copy this to a private location (outside the repo) and point
# GRINDR_OAUTH_KEYSTORE_PROPERTIES at it when building a signed release:
#
#   GRINDR_OAUTH_KEYSTORE_PROPERTIES=/path/to/keystore.properties \
#     ./gradlew :app:assembleRelease
#
# app/build.gradle.kts reads it directly at build time; without it the release
# APK is left unsigned. Never commit your real JKS or this file with real values.

# storeFile may use `~/` for your home directory.
# keyAlias must match whatever you passed to `keytool -alias ...` when you
# created the JKS — BUILDING.md's example uses `grindr-google-oauth`.
storeFile=~/.config/grindr-google-oauth/release.jks
keyAlias=grindr-google-oauth
password=change-me
